+function requireArgValue(args: readonly string[], index: number, flagLabel: string): string {
+  const value = args[index];
+  if (value === undefined) {
+    console.error(`\n❌ Error: --${flagLabel} requires a value\n`);
+    process.exit(1);
+  }
+  return value;
