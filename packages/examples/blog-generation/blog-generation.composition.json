{
  "$schema": "../../../specs/schemas/composition.schema.json",
  "compositionId": "cmp_blog_gen_001",
  "projectId": "prj_mmos_examples",
  "name": "Blog Generation",
  "displayName": "End-to-end Blog Content Generation",
  "description": "AI-powered blog article generation with research, writing, review, and SEO optimization pipeline",
  "version": "1.0.0",
  "status": "active",
  "owner": {
    "projectId": "prj_mmos_examples",
    "organizationId": null,
    "workspaceId": "ws_blog_examples"
  },
  "workflows": [
    {
      "workflowId": "wf_blog_generation",
      "name": "Blog Generation Workflow",
      "displayName": "Blog Generation",
      "version": "1.0.0",
      "role": "primary",
      "enabled": true
    }
  ],
  "defaultWorkflowId": "wf_blog_generation",
  "agents": [
    {
      "agentId": "agt_researcher",
      "role": "researcher",
      "optional": false
    },
    {
      "agentId": "agt_writer",
      "role": "writer",
      "optional": false
    },
    {
      "agentId": "agt_editor",
      "role": "editor",
      "optional": false
    },
    {
      "agentId": "agt_publisher",
      "role": "publisher",
      "optional": true
    }
  ],
  "capabilities": [
    {
      "capabilityId": "cap_web_search",
      "required": true
    },
    {
      "capabilityId": "cap_text_generate",
      "required": true
    },
    {
      "capabilityId": "cap_text_summarize",
      "required": true
    },
    {
      "capabilityId": "cap_cms_publish",
      "required": false
    }
  ],
  "memory": [
    {
      "memoryId": "mem_blog_context",
      "type": "knowledge",
      "readOnly": false
    }
  ],
  "configuration": {
    "executionPolicy": {
      "mode": "sequential",
      "timeoutSeconds": 3600,
      "allowHumanIntervention": true,
      "retryPolicy": {
        "enabled": true,
        "maxAttempts": 3,
        "backoffStrategy": "exponential",
        "delaySeconds": 5
      }
    },
    "defaultRuntime": {
      "runtimeId": "run_openai",
      "provider": "OpenAI",
      "version": "1.0.0"
    },
    "environment": "development"
  },
  "metadata": {
    "author": "MMOS Team",
    "category": "content-generation",
    "useCase": "blog-automation"
  },
  "labels": {
    "type": "blog",
    "ai-powered": "true"
  },
  "timestamps": {
    "createdAt": "2026-07-12T00:00:00.000Z",
    "updatedAt": "2026-07-12T00:00:00.000Z",
    "archivedAt": null,
    "deletedAt": null
  },
  "audit": {
    "createdBy": "mmos-system",
    "updatedBy": null,
    "archivedBy": null,
    "deletedBy": null
  }
}