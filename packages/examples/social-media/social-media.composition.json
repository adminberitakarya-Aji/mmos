{
  "$schema": "../../../specs/schemas/composition.schema.json",
  "compositionId": "cmp_social_med_001",
  "projectId": "prj_mmos_examples",
  "name": "Social Media Campaign",
  "displayName": "Multi-Platform Social Media Content Generation",
  "description": "Generate and adapt social media content for Instagram, Facebook, X, and LinkedIn with audience analysis",
  "version": "1.0.0",
  "status": "active",
  "owner": {
    "projectId": "prj_mmos_examples",
    "organizationId": null,
    "workspaceId": "ws_social_examples"
  },
  "workflows": [
    {
      "workflowId": "wf_social_media",
      "name": "Social Media Workflow",
      "displayName": "Social Media Campaign",
      "version": "1.0.0",
      "role": "primary",
      "enabled": true
    }
  ],
  "defaultWorkflowId": "wf_social_media",
  "agents": [
    {
      "agentId": "agt_researcher",
      "role": "researcher",
      "optional": false
    },
    {
      "agentId": "agt_audience_analyst",
      "role": "audience-analyst",
      "optional": false
    },
    {
      "agentId": "agt_copywriter",
      "role": "copywriter",
      "optional": false
    },
    {
      "agentId": "agt_marketing",
      "role": "marketing",
      "optional": false
    },
    {
      "agentId": "agt_image_agent",
      "role": "image-agent",
      "optional": true
    },
    {
      "agentId": "agt_packaging",
      "role": "packaging",
      "optional": true
    }
  ],
  "capabilities": [
    {
      "capabilityId": "cap_knowledge_search",
      "required": true
    },
    {
      "capabilityId": "cap_audience_analyze",
      "required": true
    },
    {
      "capabilityId": "cap_text_generate",
      "required": true
    },
    {
      "capabilityId": "cap_hashtag_generate",
      "required": true
    },
    {
      "capabilityId": "cap_image_generate",
      "required": false
    },
    {
      "capabilityId": "cap_content_adapt",
      "required": true
    }
  ],
  "memory": [
    {
      "memoryId": "mem_brand_context",
      "type": "knowledge",
      "readOnly": true
    }
  ],
  "configuration": {
    "executionPolicy": {
      "mode": "sequential",
      "timeoutSeconds": 3600,
      "allowHumanIntervention": true,
      "retryPolicy": {
        "enabled": true,
        "maxAttempts": 3,
        "backoffStrategy": "exponential",
        "delaySeconds": 5
      }
    },
    "defaultRuntime": {
      "runtimeId": "run_openai",
      "provider": "OpenAI",
      "version": "1.0.0"
    },
    "environment": "development"
  },
  "metadata": {
    "author": "MMOS Team",
    "category": "social-media-automation",
    "useCase": "campaign-generation"
  },
  "labels": {
    "type": "social-media",
    "ai-powered": "true"
  },
