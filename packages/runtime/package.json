{
  "name": "@mmos/runtime",
  "version": "1.0.0",
  "description": "MMOS Reference Runtime - Orchestrator + Engine implementations",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./orchestrator": {
      "import": "./dist/orchestrator/index.js",
      "types": "./dist/orchestrator/index.d.ts"
    },
    "./engine": {
      "import": "./dist/engine/index.js",
      "types": "./dist/engine/index.d.ts"
    },
    "./registry": {
      "import": "./dist/registry/index.js",
      "types": "./dist/registry/index.d.ts"
    },
    "./loops": {
      "import": "./dist/loops/index.js",
      "types": "./dist/loops/index.d.ts"
    },
    "./loops/system": {
      "import": "./dist/loops/system/index.js",
      "types": "./dist/loops/system/index.d.ts"
    },
    "./loops/scheduler": {
      "import": "./dist/loops/scheduler/index.js",
      "types": "./dist/loops/scheduler/index.d.ts"
    },
    "./loops/execution": {
      "import": "./dist/loops/execution/index.js",
      "types": "./dist/loops/execution/index.d.ts"
    },
    "./loops/agent": {
      "import": "./dist/loops/agent/index.js",
      "types": "./dist/loops/agent/index.d.ts"
    },
    "./loops/event": {
      "import": "./dist/loops/event/index.js",
      "types": "./dist/loops/event/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@mmos/sdk": "file:../sdk"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}