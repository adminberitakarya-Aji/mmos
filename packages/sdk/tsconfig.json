{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "exactOptionalPropertyTypes": false,
    "module": "nodenext",
    "paths": {
      "@mmos/sdk/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "tsup.config.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}