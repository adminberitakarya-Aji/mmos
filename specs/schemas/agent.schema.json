{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmos.dev/specs/schemas/agent.schema.json",
  "title": "MMOS Agent Schema",
  "description": "JSON Schema for MMOS Agent object.",
  "type": "object",

  "$comment": "MMOS v1.0 - Rich Domain Schema",

  "$defs": {

    "Identity": {
      "type": "string",
      "description": "Immutable object identifier.",
      "minLength": 4,
      "maxLength": 128,
      "pattern": "^[a-z]{3}_[A-Za-z0-9_-]+$"
    },

    "SemanticVersion": {
      "type": "string",
      "description": "Semantic Version.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },

    "UUID": {
      "type": "string",
      "format": "uuid"
    },

    "DateTime": {
      "type": "string",
      "format": "date-time"
    },

    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },

    "Description": {
      "type": "string",
      "maxLength": 5000
    },

    "Metadata": {
      "type": "object",
      "description": "User-defined metadata.",
      "additionalProperties": true
    },

    "LabelMap": {
      "type": "object",
      "description": "Agent labels.",
      "additionalProperties": {
        "type": "string",
        "maxLength": 256
      }
    },

    "Timestamp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "createdAt",
        "updatedAt"
      ],
      "properties": {

        "createdAt": {
          "$ref": "#/$defs/DateTime"
        },

        "updatedAt": {
          "$ref": "#/$defs/DateTime"
        },

        "archivedAt": {
          "oneOf": [
            {
              "$ref": "#/$defs/DateTime"
            },
            {
              "type": "null"
            }
          ]
        },

        "deletedAt": {
          "oneOf": [
            {
              "$ref": "#/$defs/DateTime"
            },
            {
              "type": "null"
            }
          ]
        }

      }
    },

    "AuditInformation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "createdBy"
      ],
      "properties": {

        "createdBy": {
          "type": "string",
          "minLength": 1
        },

        "updatedBy": {
          "type": [
            "string",
            "null"
          ]
        },

        "archivedBy": {
          "type": [
            "string",
            "null"
          ]
        },

        "deletedBy": {
          "type": [
            "string",
            "null"
          ]
        }

      }
    },

    "AgentStatus": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "active",
        "inactive",
        "deprecated",
        "archived",
        "deleted"
      ]
    },

    "AgentType": {
      "type": "string",
      "enum": [
        "system",
        "assistant",
        "worker",
        "planner",
        "coordinator",
        "reviewer",
        "validator",
        "human",
        "custom"
      ]
    }

  }
}

,
    "RuntimeReference": {
      "type": "object",
      "description": "Preferred Runtime used to execute this Agent.",
      "additionalProperties": false,
      "required": [
        "runtimeId"
      ],
      "properties": {

        "runtimeId": {
          "$ref": "#/$defs/Identity"
        },

        "provider": {
          "type": "string"
        },

        "version": {
          "$ref": "#/$defs/SemanticVersion"
        }

      }
    },

    "CapabilityReference": {
      "type": "object",
      "description": "Capability exposed or required by this Agent.",
      "additionalProperties": false,
      "required": [
        "capabilityId"
      ],
      "properties": {

        "capabilityId": {
          "$ref": "#/$defs/Identity"
        },

        "version": {
          "$ref": "#/$defs/SemanticVersion"
        },

        "required": {
          "type": "boolean",
          "default": true
        }

      }
    },

    "MemoryReference": {
      "type": "object",
      "description": "Memory resource available to the Agent.",
      "additionalProperties": false,
      "required": [
        "memoryId",
        "type"
      ],
      "properties": {

        "memoryId": {
          "$ref": "#/$defs/Identity"
        },

        "type": {
          "type": "string",
          "enum": [
            "conversation",
            "knowledge",
            "vector",
            "document",
            "session",
            "cache"
          ]
        },

        "readOnly": {
          "type": "boolean",
          "default": false
        }

      }
    },

    "ProviderReference": {
      "type": "object",
      "description": "AI provider used by the Agent.",
      "additionalProperties": false,
      "required": [
        "provider"
      ],
      "properties": {

        "provider": {
          "type": "string"
        },

        "region": {
          "type": [
            "string",
            "null"
          ]
        }

      }
    },

    "ModelReference": {
      "type": "object",
      "description": "AI model selected for the Agent.",
      "additionalProperties": false,
      "required": [
        "model"
      ],
      "properties": {

        "model": {
          "type": "string"
        },

        "version": {
          "type": [
            "string",
            "null"
          ]
        },

        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "default": 0.7
        },

        "maxTokens": {
          "type": "integer",
          "minimum": 1
        }

      }
    },

    "InstructionDefinition": {
      "type": "object",
      "description": "Base instruction (system prompt) for the Agent.",
      "additionalProperties": false,
      "required": [
        "content"
      ],
      "properties": {

        "content": {
          "type": "string"
        },

        "format": {
          "type": "string",
          "enum": [
            "plain",
            "markdown"
          ],
          "default": "markdown"
        }

      }
    },

    "ToolReference": {
      "type": "object",
      "description": "Tool that may be invoked by the Agent.",
      "additionalProperties": false,
      "required": [
        "toolId",
        "name"
      ],
      "properties": {

        "toolId": {
          "$ref": "#/$defs/Identity"
        },

        "name": {
          "$ref": "#/$defs/NonEmptyString"
        },

        "required": {
          "type": "boolean",
          "default": false
        }

      }
    },

    "ExecutionPolicy": {
      "type": "object",
      "description": "Execution behavior of the Agent.",
      "additionalProperties": false,
      "properties": {

        "allowParallel": {
          "type": "boolean",
          "default": true
        },

        "allowStreaming": {
          "type": "boolean",
          "default": true
        },

        "allowToolCalling": {
          "type": "boolean",
          "default": true
        },

        "allowHumanEscalation": {
          "type": "boolean",
          "default": true
        }

      }
    },

    "Limits": {
      "type": "object",
      "description": "Operational limits applied to the Agent.",
      "additionalProperties": false,
      "properties": {

        "maxExecutionSeconds": {
          "type": "integer",
          "minimum": 1,
          "default": 600
        },

        "maxRetries": {
          "type": "integer",
          "minimum": 0,
          "default": 3
        },

        "maxContextTokens": {
          "type": "integer",
          "minimum": 1
        }

      }
    },

    "SecurityPolicy": {
      "type": "object",
      "description": "Security constraints applied to the Agent.",
      "additionalProperties": false,
      "properties": {

        "allowExternalNetwork": {
          "type": "boolean",
          "default": false
        },

        "allowFileAccess": {
          "type": "boolean",
          "default": false
        },

        "allowSecrets": {
          "type": "boolean",
          "default": false
        },

        "sandboxed": {
          "type": "boolean",
          "default": true
        }

      }
    }

    ,

  "additionalProperties": false,

  "required": [
    "agentId",
    "name",
    "type",
    "version",
    "status",
    "runtime",
    "provider",
    "model",
    "instruction",
    "executionPolicy",
    "timestamps",
    "audit"
  ],

  "properties": {

    "agentId": {
      "$ref": "#/$defs/Identity"
    },

    "name": {
      "$ref": "#/$defs/NonEmptyString"
    },

    "displayName": {
      "type": "string",
      "maxLength": 256
    },

    "description": {
      "$ref": "#/$defs/Description"
    },

    "version": {
      "$ref": "#/$defs/SemanticVersion"
    },

    "status": {
      "$ref": "#/$defs/AgentStatus"
    },

    "type": {
      "$ref": "#/$defs/AgentType"
    },

    "runtime": {
      "$ref": "#/$defs/RuntimeReference"
    },

    "provider": {
      "$ref": "#/$defs/ProviderReference"
    },

    "model": {
      "$ref": "#/$defs/ModelReference"
    },

    "instruction": {
      "$ref": "#/$defs/InstructionDefinition"
    },

    "capabilities": {
      "type": "array",
      "description": "Capabilities exposed or required by this Agent.",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/CapabilityReference"
      }
    },

    "memory": {
      "type": "array",
      "description": "Memory resources available to this Agent.",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/MemoryReference"
      }
    },

    "tools": {
      "type": "array",
      "description": "Tools that may be invoked by this Agent.",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/ToolReference"
      }
    },

    "executionPolicy": {
      "$ref": "#/$defs/ExecutionPolicy"
    },

    "limits": {
      "$ref": "#/$defs/Limits"
    },

    "security": {
      "$ref": "#/$defs/SecurityPolicy"
    },

    "metadata": {
      "$ref": "#/$defs/Metadata"
    },

    "labels": {
      "$ref": "#/$defs/LabelMap"
    },

    "timestamps": {
      "$ref": "#/$defs/Timestamp"
    },

    "audit": {
      "$ref": "#/$defs/AuditInformation"
    },

    "extensions": {
      "type": "object",
      "description": "Reserved extension point for future MMOS versions and plugins.",
      "additionalProperties": true
    }

  }

  ,

  "examples": [
    {
      "agentId": "agt_writer",

      "name": "news-writer-agent",
      "displayName": "News Writer Agent",
      "description": "AI Agent responsible for generating news articles from structured editorial input.",

      "version": "1.0.0",
      "status": "active",
      "type": "worker",

      "runtime": {
        "runtimeId": "run_default",
        "provider": "MMOS Runtime",
        "version": "1.0.0"
      },

      "provider": {
        "provider": "OpenAI",
        "region": "global"
      },

      "model": {
        "model": "gpt-5.5",
        "version": null,
        "temperature": 0.7,
        "maxTokens": 8000
      },

      "instruction": {
        "content": "You are a professional news writer. Produce factual, objective, well-structured articles following the editorial guidelines.",
        "format": "markdown"
      },

      "capabilities": [
        {
          "capabilityId": "cap_generate_text",
          "version": "1.0.0",
          "required": true
        },
        {
          "capabilityId": "cap_fact_check",
          "version": "1.0.0",
          "required": false
        }
      ],

      "memory": [
        {
          "memoryId": "mem_editorial_guidelines",
          "type": "knowledge",
          "readOnly": true
        },
        {
          "memoryId": "mem_conversation",
          "type": "conversation",
          "readOnly": false
        }
      ],

      "tools": [
        {
          "toolId": "tol_web_search",
          "name": "Web Search",
          "required": false
        },
        {
          "toolId": "tol_article_formatter",
          "name": "Article Formatter",
          "required": true
        }
      ],

      "executionPolicy": {
        "allowParallel": true,
        "allowStreaming": true,
        "allowToolCalling": true,
        "allowHumanEscalation": true
      },

      "limits": {
        "maxExecutionSeconds": 600,
        "maxRetries": 3,
        "maxContextTokens": 32000
      },

      "security": {
        "allowExternalNetwork": false,
        "allowFileAccess": false,
        "allowSecrets": false,
        "sandboxed": true
      },

      "metadata": {
        "department": "editorial",
        "team": "news",
        "template": "daily-news"
      },

      "labels": {
        "language": "id",
        "category": "news",
        "tier": "production"
      },

      "timestamps": {
        "createdAt": "2026-07-10T08:00:00Z",
        "updatedAt": "2026-07-10T09:30:00Z",
        "archivedAt": null,
        "deletedAt": null
      },

      "audit": {
        "createdBy": "admin",
        "updatedBy": "platform-admin",
        "archivedBy": null,
        "deletedBy": null
      },

      "extensions": {}
    }
  ]
}